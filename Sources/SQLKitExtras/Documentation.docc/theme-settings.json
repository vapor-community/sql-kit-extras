{
  "theme": {
    "aside":  { "border-radius": "16px", "border-width": "3px", "border-style": "double" },
    "border-radius": "0",
    "button": { "border-radius": "16px", "border-width": "1px", "border-style": "solid" },
    "code":   { "border-radius": "16px", "border-width": "1px", "border-style": "solid" },
    "color": {
      "sqlkitextras": { "dark": "hsl(160 100% 54%)", "light": "hsl(167 100% 44%)" },
      "documentation-intro-fill": {
        "dark":  "radial-gradient(circle at top, var(--color-sqlkitextras)  0%, #000000 100%)",
        "light": "radial-gradient(circle at top, var(--color-sqlkitextras)  0%, #f0f0f0 100%)"
      },
      "documentation-intro-accent": "var(--color-sqlkitextras)",
      "documentation-intro-figure": { "dark": "#fff", "light": "#000" },
      "logo-fill":  { "dark": "#f1f1f1", "light": "#111" },
      "fill":       { "dark": "#000", "light": "#fff" }
    },
    "icons": { "technology": "/images/SQLKitExtras/sql-kit-extras.svg" }
  },
  "features": {
    "quickNavigation": { "enable": true },
    "i18n": { "enable": true }
  }
}
